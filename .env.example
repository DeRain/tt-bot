# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Required: Comma-separated Telegram user IDs allowed to use the bot
TELEGRAM_ALLOWED_USERS=123456789,987654321

# Required: qBittorrent WebUI URL (overridden to http://qbittorrent:8080 in docker-compose.yml)
QBITTORRENT_URL=http://localhost:8080

# Required: qBittorrent WebUI credentials
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin

# Optional: How often to poll for completed downloads (default: 30s)
POLL_INTERVAL=30s
